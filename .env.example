# ─── App ───────────────────────────────────────────────────
APP_NAME=CANMOS-NITI
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_DEBUG=true

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://canmos:canmos_secret@postgres:5432/canmos_niti

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── MinIO ─────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=canmos_admin
MINIO_SECRET_KEY=canmos_secret_storage
MINIO_BUCKET_DOCUMENTS=documents
MINIO_SECURE=false

# ─── Qdrant ────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── Ollama ────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PREMIUM_MONTHLY=price_monthly_id
STRIPE_PRICE_PREMIUM_ANNUAL=price_annual_id

# ─── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@canmos-niti.com.br

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://canmos-niti.vercel.app
