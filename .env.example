# Application
APP_NAME=CANMOS-NITI
APP_ENV=development
DEBUG=True

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database - Supabase PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-PROJECT].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE=your-supabase-service-role-key

# MinIO Storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=canmos-documents
MINIO_SECURE=False

# Ollama AI
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi3:mini

# Qdrant Vector DB
QDRANT_HOST=http://qdrant:6333
QDRANT_COLLECTION=tax_knowledge

# OCR
OCR_ENGINE_PRIMARY=paddleocr
OCR_ENGINE_FALLBACK=tesseract
OCR_CONFIDENCE_THRESHOLD=0.7

# Tax Engine
TAX_YEAR_DEFAULT=2025
TAX_IRPF_TABLE_VERSION=2025

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Docker Compose Profiles (set to enable OCR service)
# COMPOSE_PROFILES=ocr
